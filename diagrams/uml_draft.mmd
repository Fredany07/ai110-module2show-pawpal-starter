classDiagram
    %% PawPal+ — pet care planning app
    %% Four core classes: Owner, Pet, Task, Scheduler

    class Owner {
        +str name
        +int minutes_available
        +list~str~ preferences
        +add_pet(pet Pet) void
        +set_availability(minutes int) void
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +bool recurring
        +priority_score() int
    }

    class Scheduler {
        +int minutes_available
        +list~Task~ tasks
        +build_plan() list~Task~
        +sort_by_priority() list~Task~
        +filter_by_time() list~Task~
        +explain() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler --> Task : schedules
